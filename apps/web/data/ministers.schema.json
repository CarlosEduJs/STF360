{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Ministers Data Schema",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "id",
      "name",
      "role",
      "position",
      "appointedBy",
      "appointedAt",
      "birthYear",
      "birthState",
      "education",
      "photoUrl",
      "bio",
      "news",
      "decisions"
    ],
    "properties": {
      "id": { "type": "string", "description": "Slug do ministro (ex: ministro-alpha)" },
      "name": { "type": "string" },
      "role": { "type": "string" },
      "position": { "type": "string" },
      "appointedBy": { "type": "string" },
      "appointedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
      "birthYear": { "type": "integer" },
      "birthState": { "type": "string" },
      "education": { "type": "string" },
      "photoUrl": { "type": "string", "format": "uri" },
      "bio": { "type": "string" },
      "news": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["title", "url", "source", "publishedAt"],
          "properties": {
            "title": { "type": "string" },
            "url": { "type": "string", "format": "uri" },
            "source": { "type": "string" },
            "publishedAt": { "type": "string" }
          }
        }
      },
      "decisions": {
        "type": "array",
        "items": {
          "type": "object",
          "required": ["case", "type", "outcome", "date", "sourceUrl"],
          "properties": {
            "case": { "type": "string" },
            "type": { "type": "string" },
            "outcome": { "type": "string" },
            "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
            "sourceUrl": { "type": "string", "format": "uri" },
            "summary": { "type": "string" }
          }
        }
      }
    }
  }
}
